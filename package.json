    "@tanstack/react-query": "^5.56.2",
    "axios": "^1.7.7",
    "date-fns": "^3.6.0",
    "expo": "~51.0.28",
    "expo-constants": "~16.0.2",
    "expo-dev-client": "^56.0.20",
    "expo-font": "~12.0.10",
    "expo-linear-gradient": "~13.0.2",
    "expo-linking": "~6.3.1",
    "expo-notifications": "~0.28.19",
