    "@tanstack/react-query": "^5.56.2",
    "axios": "^1.7.7",
    "date-fns": "^3.6.0",
    "expo": "~53.0.0",
    "expo-asset": "~11.1.7",
    "expo-constants": "~17.1.8",
    "expo-dev-client": "~5.2.4",
    "expo-file-system": "~18.1.11",
    "expo-font": "~13.3.2",
    "expo-linear-gradient": "~14.1.5",
