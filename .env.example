# Klak Mobile — Environment Variables
# Copy this to .env.local and fill in real values
# Never commit .env.local to version control

# Backend API base URL
# Local dev (Android emulator): http://10.0.2.2:3000
# Local dev (iOS sim / Expo Go): http://localhost:3000
# Production:
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:3000

# Mono Connect public key (get from mono.co dashboard)
EXPO_PUBLIC_MONO_PUBLIC_KEY=live_pk_REPLACE_ME

# Google OAuth client ID (for social sign-in)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=REPLACE_ME.apps.googleusercontent.com

# App environment
EXPO_PUBLIC_APP_ENV=development
