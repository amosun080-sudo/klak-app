# Klak Mobile — Environment Variables
# Copy this to .env.local and fill in real values
# Never commit .env.local to version control

# ─────────────────────────────────────────────────────────────────────────────
# Backend API Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Production API base URL
EXPO_PUBLIC_API_BASE_URL=https://klak-backend.onrender.com

# Development URLs (for reference):
# Local dev (Android emulator): http://10.0.2.2:3000
# Local dev (iOS sim / Expo Go): http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# Third-party Service Keys
# ─────────────────────────────────────────────────────────────────────────────

# Mono Connect public key (get from mono.co dashboard)
# Required for Nigerian bank account linking
EXPO_PUBLIC_MONO_PUBLIC_KEY=live_pk_YOUR_MONO_PUBLIC_KEY_HERE

# Google OAuth client ID (for social sign-in, if implemented)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# ─────────────────────────────────────────────────────────────────────────────
# App Configuration  
# ─────────────────────────────────────────────────────────────────────────────

# App environment (development | staging | production)
EXPO_PUBLIC_APP_ENV=production

# Expo CLI optimizations
EXPO_NO_TELEMETRY=1
EXPO_NO_DOCTOR=1
EXPO_SKIP_MODULE_UPDATE=1
